{new HamScreen
   dx_info_screen
   (panels meta background_confirmation_panel dialog_panel)
   (focus dialog_panel)
   (enter {dialog_panel set_ok "Dance Central Definitive\nhttps://github.com/DanceCentralDefinitive/dance-central-definitive\n" FALSE})
   (NAV_SELECT_MSG {ui goto_screen dx_options_screen})
}

{new OptionsPanel
   dx_options_panel
   (file "../../ui/options/options.milo")
   (focus right_hand.hnl)
   (focus_index 0)
   (pending_show_keyboard FALSE)
   (pending_purchase_offer FALSE)
   (offer_string "")
   (top_index 0)
   (back_token back)
   (back_screen options_screen)
   (enter
      {platform_mgr add_sink $this (ui_changed)}
      {set [pending_show_keyboard] FALSE}
      {set [pending_purchase_offer] FALSE}
      {set [offer_string] ""}
      {if {! {$this exists dx_options_panel_provider.hnp}}
         {new HamNavProvider dx_options_panel_provider.hnp}
      }
      {dx_options_panel_provider.hnp append_nav_item}
      {dx_options_panel_provider.hnp append_nav_item}
      {dx_options_panel_provider.hnp append_nav_item}
      ;{dx_options_panel_provider.hnp append_nav_item}
      ;{dx_options_panel_provider.hnp append_nav_item}
	  
      {dx_options_panel_provider.hnp set_label 0 definitive_modifiers}
	  {dx_options_panel_provider.hnp set_label 1 definitive_postprocs_toggle}
	  {dx_options_panel_provider.hnp set_label 2 definitive_info}
	  
      ; {dx_options_panel_provider.hnp set_label 2 "Pack Friends Token"}
      ; {dx_options_panel_provider.hnp set_label 3 "Show Friends Token"}
      ; {dx_options_panel_provider.hnp set_label 4 definitive_info}
	  
      {right_hand.hnl set_provider dx_options_panel_provider.hnp}
      {right_hand.hnl scroll_to_index [focus_index] [top_index]}
   )
   (exit
      {platform_mgr remove_sink $this ui_changed}
      {set [top_index] {right_hand.hnl get_top_index}}
   )
   SELECT_RIGHT_LIST_TOKEN
   (poll SLIDE_RIGHT_LIST_ITEM)
   (NAV_SELECT_MSG
      {switch $name
         (definitive_modifiers
            {ui goto_screen dx_modifiers_screen}
         )
		 
         ; ("Pack Friends Token"
         ;    {do
         ;       ($profile {profile_mgr get_active_profile})
         ;       {print $profile}
         ;       {if $profile
         ;          {do
         ;             ($slot 0)
         ;             ($value 1337)
         ;             ($packed {'+' $value {'*' 1000000 $slot}})
         ;             {$profile set_upload_friends_token $packed}
         ;             {cheat_display show
         ;                {sprintf
         ;                   "Saved SLOT %i -> VALUE %i (packed=%i)"
         ;                   $slot
         ;                   $value
         ;                   $packed
         ;                }
         ;             }
         ;          }
         ;          {cheat_display show "No active profile"}
         ;       }
         ;    }
         ; )
         ; ("Show Friends Token"
         ;    {do
         ;       ($profile {profile_mgr get_active_profile})
         ;       {if $profile
         ;          {do
         ;             ($packed {$profile get_upload_friends_token})
         ;             ($slot {int {/ $packed 1000000}})
         ;             ($value {mod $packed 1000000})
         ;             {cheat_display show
         ;                {sprintf
         ;                   "SLOT %i -> VALUE %i (packed=%i)"
         ;                   $slot
         ;                   $value
         ;                   $packed
         ;                }
         ;             }
         ;          }
         ;          {cheat_display show "No active profile"}
         ;       }
         ;    }
         ; )
		 
		 (definitive_postprocs_toggle
            {rnd toggle_all_postprocs}
         )
         (definitive_info
            {ui goto_screen dx_info_screen}
         )
      }
   )
   (NAV_HIGHLIGHT_MSG
      {switch $component
         (right_hand.hnl {set [focus_index] $index})
      }
   )
   (BUTTON_DOWN_MSG
      {switch $action
         (
            (kAction_Cancel)
            {$this on_back}
         )
         kDataUnhandled
      }
   )
   (on_back
      {saveload_mgr autosave}
      {ui goto_screen [back_screen]}
   )
   (controller_req_op_complete
      ($success)
      {if {== $success TRUE}
         {shell_input set_last_select_in_controller_mode TRUE}
         {if_else {platform_mgr is_guide_showing}
            {set [pending_show_keyboard] TRUE}
            {$this show_keyboard}
         }
      }
   )
}

{new HamScreen
   dx_options_screen
   (panels meta background_panel dx_options_panel)
   (focus dx_options_panel)
   (back options_screen)
   (handle_global_commands TRUE)
   (enter {voice_input_panel activate_voice_context dx_options_screen})
   (on_voice_command
      ($command)
      {switch $command
         BACRO
         {dx_options_panel select_right_list_token $command}
      }
   )
   (on_global_voice_command
      ($command)
      {switch $command
         (hidden_global_options)
         {on_global_voice_command $command}
      }
   )
}