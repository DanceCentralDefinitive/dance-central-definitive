{new OptionsPanel
   dx_autoplay_panel
   (file "../../../ui/options/options.milo")
   (focus right_hand.hnl)
   (focus_index 0)
   (pending_show_keyboard FALSE)
   (pending_purchase_offer FALSE)
   (offer_string "")
   (top_index 0)
   (back_token back)
   (back_screen dx_options_screen)
   (enter
      {platform_mgr add_sink $this (ui_changed)}
      {set [pending_show_keyboard] FALSE}
      {set [pending_purchase_offer] FALSE}
      {set [offer_string] ""}
      {if {! {$this exists dx_autoplay_panel_provider.hnp}}
         {new HamNavProvider dx_autoplay_panel_provider.hnp}
      }
      {dx_autoplay_panel_provider.hnp append_nav_item}
      {dx_autoplay_panel_provider.hnp append_nav_item}
      {dx_autoplay_panel_provider.hnp set_label 0 "Player 1 (Right)"}
      {dx_autoplay_panel_provider.hnp set_label 1 "Player 2 (Left)"}
      {right_hand.hnl set_provider dx_autoplay_panel_provider.hnp}
      {right_hand.hnl scroll_to_index [focus_index] [top_index]}
   )
   (exit
      {platform_mgr remove_sink $this ui_changed}
      {set [top_index] {right_hand.hnl get_top_index}}
   )
   SELECT_RIGHT_LIST_TOKEN
   (poll SLIDE_RIGHT_LIST_ITEM)
   (NAV_SELECT_MSG
      {switch $name
         ("Player 1 (Right)"
            {set $dx_options_target_player 1}
            {ui goto_screen dx_autoplay_diff_screen}
         )
         ("Player 2 (Left)"
            {set $dx_options_target_player 2}
            {ui goto_screen dx_autoplay_diff_screen}
         )
      }
   )
   (NAV_HIGHLIGHT_MSG
      {switch $component
         (right_hand.hnl {set [focus_index] $index})
      }
   )
   (BUTTON_DOWN_MSG
      {switch $action
         (
            (kAction_Cancel)
            {$this on_back}
         )
         kDataUnhandled
      }
   )
   (on_back
      {saveload_mgr autosave}
      {ui goto_screen [back_screen]}
   )
   (controller_req_op_complete
      ($success)
      {if {== $success TRUE}
         {shell_input set_last_select_in_controller_mode TRUE}
         {if_else {platform_mgr is_guide_showing}
            {set [pending_show_keyboard] TRUE}
            {$this show_keyboard}
         }
      }
   )
}

{new HamScreen
   dx_autoplay_screen
   (panels meta background_panel dx_autoplay_panel)
   (focus dx_autoplay_panel)
   (back options_screen)
   (handle_global_commands TRUE)
   (enter {voice_input_panel activate_voice_context dx_options_screen})
   (on_voice_command
      ($command)
      {switch $command
         BACRO
         {dx_autoplay_panel select_right_list_token $command}
      }
   )
   (on_global_voice_command
      ($command)
      {switch $command
         (hidden_global_options)
         {on_global_voice_command $command}
      }
   )
}